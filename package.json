{
  "name": "cambio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"partykit dev\" --names \"vite,party\" --prefix-colors \"cyan,yellow\"",
    "dev:client": "vite",
    "dev:party": "partykit dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "partykit deploy"
  },
  "dependencies": {
    "partysocket": "^1.1.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "partykit": "^0.0.115",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.21"
  }
}
